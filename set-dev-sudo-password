#!/usr/bin/env bash
set -euo pipefail

DEV_USERNAME="${DEV_USERNAME:-${SUDO_USER:-dev}}"
MARKER_FILE="/var/lib/devcontainer/sudo-password-set"
SUDOERS_FILE="/etc/sudoers.d/${DEV_USERNAME}"

if [[ "$(id -u)" != "0" ]]; then
  echo "[ERROR] This helper must run as root." >&2
  exit 1
fi

if ! id "$DEV_USERNAME" >/dev/null 2>&1; then
  echo "[ERROR] User '$DEV_USERNAME' does not exist." >&2
  exit 1
fi

IFS= read -r password
if [[ -z "$password" ]]; then
  echo "[ERROR] Password cannot be empty." >&2
  exit 1
fi

printf '%s:%s\n' "$DEV_USERNAME" "$password" | chpasswd
unset password

echo "${DEV_USERNAME} ALL=(ALL) ALL" > "$SUDOERS_FILE"
chmod 0440 "$SUDOERS_FILE"

mkdir -p "$(dirname "$MARKER_FILE")"
touch "$MARKER_FILE"
chmod 0644 "$MARKER_FILE"
